cd ~
touch "${USER}_part3.log"
mkdir -p D1/D2/D3
touch D1/D2/file.txt
echo 'это текст для file.txt' > D1/D2/file.txt
cat D1/D2/file.txt
ln -s ../file.txt D1/D2/D3/file_symlink.txt
ln D1/D2/file.txt D1/D2/D3/file_hard1.txt
ln D1/D2/file.txt D1/D2/D3/file_hard2.txt
ls -li D1/D2/file.txt D1/D2/D3/*
cat D1/D2/D3/file_symlink.txt
cat D1/D2/D3/file_hard1.txt
cat D1/D2/D3/file_hard2.txt
mv D1/D2/file.txt D1/file.txt
ls -li D1/file.txt D1/D2/D3/*
cat D1/D2/D3/file_hard1.txt
cat D1/D2/D3/file_hard2.txt
cat D1/D2/D3/file_symlink.txt
rm -r D1/D2
find D1
find / -type f -size +20M 2>/dev/null | head
du -h /usr/bin/x86_64-linux-gnu-lto-dump-12
find / -type f -mtime -1 2>/dev/null | head
which find
file "$(which find)"
file /boot/initrd.img*
